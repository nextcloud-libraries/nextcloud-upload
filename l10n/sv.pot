msgid "\"{segment}\" is a forbidden file or folder name."
msgstr "\"{segment}\" får inte användas som fil- eller mappnamn."

msgid "\"{segment}\" is a forbidden file type."
msgstr "\"{segment}\" är en otillåten filtyp."

msgid "\"{segment}\" is not allowed inside a file or folder name."
msgstr "\"{segment}\" får inte ingå i ett fil- eller mappnamn."

msgid "{count} file conflict"
msgid_plural "{count} files conflict"
msgstr[0] "{count} filkonflikt"
msgstr[1] "{count} filkonflikter"

msgid "{count} file conflict in {dirname}"
msgid_plural "{count} file conflicts in {dirname}"
msgstr[0] "{count} filkonflikt i {dirname}"
msgstr[1] "{count} filkonflikter i {dirname}"

msgid "{seconds} seconds left"
msgid_plural "{seconds} seconds left"
msgstr[0] "{seconds} sekund kvar"
msgstr[1] "{seconds} sekunder kvar"

#. TRANSLATORS time has the format 00:00:00
msgid "{time} left"
msgstr "{time} kvar"

msgid "a few seconds left"
msgstr "några sekunder kvar"

msgid "assembling"
msgstr "sammanfogar"

msgid "Cancel"
msgstr "Avbryt"

msgid "Cancel the entire operation"
msgstr "Avbryt hela åtgärden"

msgid "Cancel uploads"
msgstr "Avbryt uppladdningar"

msgid "Continue"
msgstr "Fortsätt"

msgid "Create new"
msgstr "Skapa ny"

msgid "estimating time left"
msgstr "beräknar återstående tid"

msgid "Existing version"
msgstr "Befintlig version"

msgid "Failed to assemble the chunks together"
msgstr "Det gick inte att sammanfoga delarna"

msgid "Failed to upload the file"
msgstr "Det gick inte att ladda upp filen"

msgid "Filenames must not end with \"{segment}\"."
msgstr "Filnamn får inte sluta med \"{segment}\"."

msgid ""
"If you select both versions, the incoming file will have a number added to "
"its name."
msgstr ""
"Om du väljer båda versionerna läggs ett nummer till i namnet på den "
"inkommande filen."

msgid "Invalid filename"
msgstr "Ogiltigt filnamn"

msgid "Last modified date unknown"
msgstr "Datumet för den senaste ändringen är okänt"

msgid "New"
msgstr "Ny"

msgid "New filename"
msgstr "Nytt filnamn"

msgid "New version"
msgstr "Ny version"

msgid "paused"
msgstr "pausad"

msgid "Preview image"
msgstr "Förhandsgranskningsbild"

msgid "Rename"
msgstr "Byt namn"

msgid "Select all checkboxes"
msgstr "Markera alla kryssrutor"

msgid "Select all existing files"
msgstr "Markera alla befintliga filer"

msgid "Select all new files"
msgstr "Markera alla nya filer"

msgid "Skip"
msgstr "Hoppa över"

msgid "Skip {count} file"
msgid_plural "Skip {count} files"
msgstr[0] "Hoppa över {count} fil"
msgstr[1] "Hoppa över {count} filer"

msgid "Skip this file"
msgstr "Hoppa över den här filen"

msgid "Unknown size"
msgstr "Okänd storlek"

msgid "Upload"
msgstr "Ladda upp"

msgid "Upload files"
msgstr "Ladda upp filer"

msgid "Upload folders"
msgstr "Ladda upp mappar"

msgid "Upload from device"
msgstr "Ladda upp från enheten"

msgid "Upload has been cancelled"
msgstr "Uppladdningen har avbrutits"

msgid "Upload has been skipped"
msgstr "Uppladdningen har hoppats över"

msgid "Upload of \"{folder}\" has been skipped"
msgstr "Uppladdningen av \"{folder}\" har hoppats över"

msgid "Upload progress"
msgstr "Uppladdningsförlopp"

msgid ""
"When an incoming folder is selected, any conflicting files within it will "
"also be overwritten."
msgstr ""
"När en inkommande mapp väljs skrivs även alla filer med konflikter i den "
"över."

msgid ""
"When an incoming folder is selected, the content is written into the "
"existing folder and a recursive conflict resolution is performed."
msgstr ""
"När en inkommande mapp väljs skrivs innehållet in i den befintliga mappen "
"och konflikterna löses rekursivt."

msgid "Which files do you want to keep?"
msgstr "Vilka filer vill du behålla?"

msgid ""
"You can either rename the file, skip this file or cancel the whole "
"operation."
msgstr ""
"Du kan antingen byta namn på filen, hoppa över den eller avbryta hela "
"åtgärden."

msgid "You need to select at least one version of each file to continue."
msgstr "Du måste välja minst en version av varje fil för att kunna fortsätta."
